# Configuration de la base de données PostgreSQL
DATABASE_URL="postgresql://username:password@localhost:5436/geneaia_local?schema=public"

# Port du serveur backend
PORT=3001

# Configuration JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# CORS — origines autorisées (séparées par des virgules)
CORS_ORIGIN="http://localhost:5173"

# Environnement
NODE_ENV="development"

# URL publique de l'API (proxy fichiers uploadés)
API_PUBLIC_URL="http://localhost:3001"
STORAGE_USE_PROXY="true"

# ─── MinIO / S3 — stockage photos & documents ───────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="geneaia_minio"
S3_SECRET_KEY="geneaia_minio_password"
S3_BUCKET="geneaia"
S3_REGION="us-east-1"
S3_PUBLIC_URL="http://localhost:9000/geneaia"

STORAGE_PHOTO_PREFIX="photos"
STORAGE_DOCUMENT_PREFIX="documents"
STORAGE_PHOTO_MAX_MB="5"
STORAGE_DOCUMENT_MAX_MB="20"
