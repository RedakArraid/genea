# ─── Base de données ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://geneaia_user:geneaia_password@localhost:5436/geneaia_local?schema=public"
PORT=3001
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
NODE_ENV=development

# ─── URLs publiques (adapter les ports si conflit Docker) ─────────────────────
CORS_ORIGIN="http://localhost:5174"
FRONTEND_URL="http://localhost:5174"
API_PUBLIC_URL="http://localhost:3002"

# ─── Stockage MinIO / S3 ─────────────────────────────────────────────────────
# Local : MinIO. VPS : Cloudflare R2 (voir docs/CLOUDFLARE_R2.md) :
#   S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   S3_REGION=auto — STORAGE_AUTO_INIT=false
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="geneaia_minio"
S3_SECRET_KEY="geneaia_minio_password"
S3_BUCKET="geneaia"
S3_REGION="us-east-1"
S3_PUBLIC_URL="http://localhost:9000/geneaia"
# true = URLs via /api/uploads/file/... (recommandé) ; false = URL MinIO directe
STORAGE_USE_PROXY=true
# true (MinIO) = crée le bucket au démarrage ; false (R2) = le bucket doit exister
STORAGE_AUTO_INIT=true
STORAGE_PHOTO_PREFIX=photos
STORAGE_DOCUMENT_PREFIX=documents
STORAGE_PHOTO_MAX_MB=5
STORAGE_DOCUMENT_MAX_MB=20

# ─── Paiements internationaux (USD via Paystack) ─────────────────────────────
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_PUBLIC_KEY="pk_test_..."

# ─── SMTP (OTP par email) ────────────────────────────────────────────────────
# Local Docker : Mailpit (SMTP 1025, interface http://localhost:8025)
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="GeneaIA <noreply@geneaia.app>"

# Durée de validité du code OTP (minutes)
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_COOLDOWN_SECONDS=60
