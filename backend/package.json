{
  "name": "geneamap-backend",
  "version": "0.1.0",
  "description": "Backend API for geneamap application",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "dev:watch": "nodemon src/index.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "seed:challenge": "node scripts/seed-challenge-family.js",
    "seed:challenge:replace": "node scripts/seed-challenge-family.js --replace",
    "test": "jest --forceExit",
    "lint": "node --check src/index.js && bash ../scripts/lint-backend.sh"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@prisma/client": "^5.11.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.13.8",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.15.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "prisma": "^5.11.0",
    "supertest": "^6.3.3"
  }
}
