generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TreeType {
  GENEALOGY
  ORGANIZATION
}

enum TreeBackgroundMode {
  NONE
  COVER
  REPEAT
}

enum Plan {
  SOLO
  FAMILY
  PATRIMONY
}

enum TreeVisibility {
  PRIVATE
  SHARED
  PUBLIC
}

enum CollaboratorRole {
  VIEWER
  EDITOR
}

enum UserRole {
  USER
  ADMIN
}

model Edge {
  id           String     @id @default(uuid())
  source       String
  target       String
  type         String?
  sourceHandle String?
  targetHandle String?
  data         Json?
  treeId       String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  FamilyTree   FamilyTree @relation(fields: [treeId], references: [id], onDelete: Cascade)
}

model FamilyTree {
  id               String             @id @default(uuid())
  name             String
  description      String?
  isPublic         Boolean            @default(false)
  visibility       TreeVisibility     @default(PRIVATE)
  isDemo           Boolean            @default(false)
  demoForkOwnerId  String?            @unique
  matchingOptIn    Boolean            @default(false)
  treeType             TreeType           @default(GENEALOGY)
  backgroundImageUrl   String?
  backgroundMode       TreeBackgroundMode @default(NONE)
  backgroundOpacity    Float              @default(0.35)
  backgroundOverlay    Boolean            @default(true)
  backgroundTileSize   Int                @default(160)
  orgLexicon           Json?
  createdAt            DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  ownerId          String
  Edge             Edge[]
  User             User               @relation(fields: [ownerId], references: [id])
  NodePosition     NodePosition[]
  Person           Person[]
  TreeCollaborator TreeCollaborator[]
  TreeInvite       TreeInvite[]
}

model NodePosition {
  id         String     @id @default(uuid())
  nodeId     String
  x          Float
  y          Float
  treeId     String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  FamilyTree FamilyTree @relation(fields: [treeId], references: [id], onDelete: Cascade)
}

model Person {
  id                                         String         @id @default(uuid())
  firstName                                  String
  lastName                                   String
  birthDate                                  DateTime?
  birthPlace                                 String?
  deathDate                                  DateTime?
  occupation                                 String?
  biography                                  String?
  gender                                     String?
  photoUrl                                   String?
  PersonDocument                             PersonDocument[]
  createdAt                                  DateTime       @default(now())
  updatedAt                                  DateTime       @updatedAt
  treeId                                     String
  FamilyTree                                 FamilyTree     @relation(fields: [treeId], references: [id], onDelete: Cascade)
  Relationship_Relationship_sourceIdToPerson Relationship[] @relation("Relationship_sourceIdToPerson")
  Relationship_Relationship_targetIdToPerson Relationship[] @relation("Relationship_targetIdToPerson")
  PersonRevision                             PersonRevision[]
}

/// Correspondance entre une entité de l'arbre démo canonique et son clone
/// dans la copie personnelle forkée d'un utilisateur (person/nodePosition/relationship/edge).
model DemoForkMapping {
  id         String   @id @default(uuid())
  forkTreeId String
  entityType String
  originalId String
  forkedId   String
  createdAt  DateTime @default(now())

  @@unique([forkTreeId, entityType, originalId])
  @@index([forkTreeId, entityType, forkedId])
}

model PersonRevision {
  id        String   @id @default(uuid())
  personId  String
  treeId    String
  userId    String
  action    String
  snapshot  Json
  createdAt DateTime @default(now())
  Person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId, createdAt])
}

model Relationship {
  id                                   String   @id @default(uuid())
  type                                 String
  sourceId                             String
  targetId                             String
  createdAt                            DateTime @default(now())
  updatedAt                            DateTime @updatedAt
  Person_Relationship_sourceIdToPerson Person   @relation("Relationship_sourceIdToPerson", fields: [sourceId], references: [id], onDelete: Cascade)
  Person_Relationship_targetIdToPerson Person   @relation("Relationship_targetIdToPerson", fields: [targetId], references: [id], onDelete: Cascade)
}

enum OtpPurpose {
  LOGIN
}

model OtpCode {
  id         String     @id @default(uuid())
  phone      String
  codeHash   String
  purpose    OtpPurpose @default(LOGIN)
  attempts   Int        @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([phone, purpose])
  @@index([expiresAt])
}

model User {
  id                 String             @id @default(uuid())
  phone              String             @unique
  email              String?            @unique
  password           String
  name               String?
  plan               Plan               @default(SOLO)
  planActive         Boolean            @default(false)
  planExpiresAt      DateTime?
  role               UserRole           @default(USER)
  locale             String             @default("fr")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  FamilyTree         FamilyTree[]
  TreeCollaborator   TreeCollaborator[]
  TreeInviteSent     TreeInvite[]       @relation("InvitedBy")
  Payment            Payment[]
}

enum PaymentProvider {
  PAYSTACK
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PromoDiscountType {
  PERCENT
  FIXED
}

model Payment {
  id          String           @id @default(uuid())
  userId      String
  reference   String           @unique
  provider    PaymentProvider
  amount      Int              /// Montant en centimes USD
  currency    String           @default("USD")
  plan        Plan
  status      PaymentStatus    @default(PENDING)
  promoCodeId String?
  metadata    Json?
  paidAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  User        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  PromoCode   PromoCode?       @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}

model PromoCode {
  id              String            @id @default(uuid())
  code            String            @unique
  description     String?
  discountType    PromoDiscountType
  discountValue   Int
  maxUses         Int?
  usedCount       Int               @default(0)
  validFrom       DateTime?
  validUntil      DateTime?
  applicablePlans Plan[]
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  Payment         Payment[]
}

model TreeCollaborator {
  id         String           @id @default(uuid())
  treeId     String
  userId     String
  role       CollaboratorRole @default(VIEWER)
  createdAt  DateTime         @default(now())
  FamilyTree FamilyTree       @relation(fields: [treeId], references: [id], onDelete: Cascade)
  User       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([treeId, userId])
}

model TreeInvite {
  id          String           @id @default(uuid())
  treeId      String
  email       String
  role        CollaboratorRole @default(VIEWER)
  token       String           @unique @default(uuid())
  status      String           @default("pending")
  invitedById String
  createdAt   DateTime         @default(now())
  FamilyTree  FamilyTree       @relation(fields: [treeId], references: [id], onDelete: Cascade)
  InvitedBy   User             @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([email])
}

model PersonDocument {
  id           String   @id @default(uuid())
  personId     String
  treeId       String
  title        String
  fileName     String
  fileUrl      String
  fileKey      String
  mimeType     String
  sizeBytes    Int
  category     String   @default("other")
  uploadedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  Person       Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([treeId])
}

/// Configuration SMTP (singleton id = "default"), modifiable via l'admin.
model SmtpSetting {
  id        String   @id @default("default")
  host      String?
  port      Int      @default(587)
  secure    Boolean  @default(false)
  user      String?
  pass      String?
  from      String?
  updatedAt DateTime @updatedAt
}

/// Configuration OpenWA WhatsApp (singleton id = "default"), modifiable via l'admin.
model OpenWaSetting {
  id        String   @id @default("default")
  enabled   Boolean  @default(false)
  baseUrl   String?
  apiKey    String?
  sessionId String?
  updatedAt DateTime @updatedAt
}
