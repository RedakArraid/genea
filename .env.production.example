# Variables pour docker-compose.prod.yml sur le VPS Contabo
# Copier vers /root/geneaia/.env avant déploiement
# (staging : mêmes variables avec préfixe STAGING_* dans /root/geneaia-staging/.env)

# ─── Base de données ─────────────────────────────────────────────────────────
PROD_DB_PASSWORD=change-me-strong-password
PROD_JWT_SECRET=change-me-jwt-secret-min-32-chars

# ─── Cloudflare R2 (stockage photos / documents) ─────────────────────────────
# Voir docs/CLOUDFLARE_R2.md pour créer les buckets et le token API.
# Le bucket (geneamap-prod / geneamap-staging) est fixé dans le compose.
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY=change-me-r2-access-key
R2_SECRET_KEY=change-me-r2-secret-key

# ─── Paiements ───────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ─── SMTP (OTP par email si l'utilisateur a un email) ────────────────────────
# Peut aussi être configuré via l'admin : /admin/smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=GeneaIA <noreply@geneamap.com>

# ─── OpenWA (OTP WhatsApp, canal principal) ──────────────────────────────────
# Peut aussi être configuré via l'admin : /admin/openwa
# OPENWA_ENABLED=false
# OPENWA_BASE_URL=http://openwa:2785/api
# OPENWA_API_KEY=
# OPENWA_SESSION_ID=

# ─── Compte admin (créé/mis à jour au démarrage du backend) ───────────────────
ADMIN_EMAIL=admin@geneamap.com
ADMIN_PASSWORD=admin123
ADMIN_PHONE=+2250700000010

# Les URLs publiques (geneamap.com, www.geneamap.com, api.geneamap.com) et la config R2 bucket/région
# sont définies dans docker-compose.prod.yml — rien d'autre à dupliquer ici.
